<!-- index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Employee Management System | Modern Enterprise</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf-autotable@3.8.2/dist/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <style>
    :root {
      --bg: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
      --glass: rgba(255, 255, 255, 0.65);
      --glass-border: rgba(255, 255, 255, 0.8);
      --text: #2d3748; --text-muted: #4a5568; --primary: #4f46e5;
      --card-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
    }
    [data-theme="dark"] {
      --bg: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      --glass: rgba(30, 41, 59, 0.7); --glass-border: rgba(255, 255, 255, 0.1);
      --text: #f8fafc; --text-muted: #cbd5e1; --primary: #818cf8;
      --card-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
    }
    body { background: var(--bg); background-attachment: fixed; color: var(--text); font-family: 'Segoe UI', sans-serif; transition: 0.3s; min-height: 100vh; }
    .glass-panel { background: var(--glass); backdrop-filter: blur(16px); border: 1px solid var(--glass-border); border-radius: 16px; box-shadow: var(--card-shadow); }
    .sidebar { min-width: 260px; height: calc(100vh - 40px); position: sticky; top: 20px; }
    .nav-link { color: var(--text); border-radius: 10px; margin-bottom: 5px; font-weight: 500; }
    .nav-link:hover, .nav-link.active { background: var(--primary); color: #fff !important; }
    .topbar { position: sticky; top: 20px; z-index: 1020; }
    .fade-in { animation: fadeIn 0.5s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .stat-icon { font-size: 2.2rem; color: var(--primary); }
    .table { color: var(--text); }
    .form-control, .form-select { background: rgba(255,255,255,0.5); border-color: var(--glass-border); color: var(--text); }
    [data-theme="dark"] .form-control, [data-theme="dark"] .form-select { background: rgba(0,0,0,0.2); color: #fff; }
    .form-control:focus, .form-select:focus { background: rgba(255,255,255,0.8); color: #000; box-shadow: 0 0 0 0.25rem rgba(79, 70, 229, 0.25); }
    [data-theme="dark"] .form-control:focus, [data-theme="dark"] .form-select:focus { background: rgba(0,0,0,0.4); color: #fff; }
    .badge-custom { padding: 0.5em 0.8em; border-radius: 8px; font-weight: 600; }
  </style>
</head>
<body>
  <div id="loadingSpinner" class="d-none position-fixed top-50 start-50 translate-middle z-index-2000">
    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"><span class="visually-hidden">Loading...</span></div>
  </div>
  <div id="root"></div>

  <!-- Employee Modal -->
  <div class="modal fade" id="empModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content glass-panel">
        <div class="modal-header border-0"><h5 class="modal-title fw-bold" id="empModalTitle">Add Employee</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <form id="empForm">
            <input type="hidden" id="empId">
            <div class="row">
              <div class="col-md-6 mb-3"><label>Name</label><input class="form-control" id="empName" required></div>
              <div class="col-md-6 mb-3"><label>Employee ID</label><input class="form-control" id="empEid" required></div>
              <div class="col-md-6 mb-3"><label>Department</label><input class="form-control" id="empDept" required></div>
              <div class="col-md-6 mb-3"><label>Trade</label><input class="form-control" id="empTrade" required></div>
              <div class="col-md-6 mb-3"><label>Nationality</label><input class="form-control" id="empNat"></div>
              <div class="col-md-6 mb-3"><label>Emirates ID</label><input class="form-control" id="empEmirates"></div>
              <div class="col-md-6 mb-3"><label>Passport</label><input class="form-control" id="empPass"></div>
              <div class="col-md-6 mb-3"><label>Phone</label><input class="form-control" id="empPhone"></div>
              <div class="col-md-6 mb-3"><label>Email</label><input type="email" class="form-control" id="empEmail"></div>
              <div class="col-md-6 mb-3"><label>Salary</label><input type="number" class="form-control" id="empSalary" required></div>
              <div class="col-md-6 mb-3"><label>Joining Date</label><input type="date" class="form-control" id="empJoin"></div>
              <div class="col-md-6 mb-3"><label>Status</label><select class="form-control" id="empStatus"><option>Active</option><option>Inactive</option></select></div>
              <div class="col-md-12 mb-3"><label>Photo URL</label><input class="form-control" id="empPhoto" placeholder="https://..."></div>
            </div>
          </form>
        </div>
        <div class="modal-footer border-0"><button class="btn btn-secondary" data-bs-dismiss="modal">Close</button><button class="btn btn-primary" onclick="saveEmployee()">Save</button></div>
      </div>
    </div>
  </div>

  <!-- Payment Modal -->
  <div class="modal fade" id="payModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content glass-panel">
        <div class="modal-header border-0"><h5 class="modal-title fw-bold">Process Payment</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <form id="payForm">
            <input type="hidden" id="paySalId">
            <div class="mb-3"><label>Payment Method</label><select id="payMethod" class="form-control"><option>Cash</option><option>Bank Transfer</option></select></div>
            <div class="mb-3"><label>Transaction ID</label><input id="payTxn" class="form-control"></div>
            <div class="mb-3"><label>Reference Number</label><input id="payRef" class="form-control"></div>
            <div class="mb-3"><label>Payment Date</label><input type="date" id="payDate" class="form-control"></div>
          </form>
        </div>
        <div class="modal-footer border-0"><button class="btn btn-secondary" data-bs-dismiss="modal">Close</button><button class="btn btn-success" onclick="processPayment()">Confirm Pay</button></div>
      </div>
    </div>
  </div>

  <div class="toast-container position-fixed bottom-0 end-0 p-3 z-index-2000">
    <div id="appToast" class="toast align-items-center text-white bg-primary border-0" role="alert"><div class="d-flex"><div class="toast-body" id="toastMsg"></div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>
  </div>

  <script>
    const INITIAL_USER = <%- JSON.stringify(user || null) %>;
    const state = { user: INITIAL_USER, employees: [], attendance: [], salaries: [], currentView: 'dashboard' };

    if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');

    const api = {
      async login(u, p) { return (await fetch('/api/login', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({username:u, password:p}) })).json(); },
      async logout() { await fetch('/api/logout', { method: 'POST' }); window.location.reload(); },
      async getState() { return (await fetch('/api/state')).json(); },
      async post(url, data) { return (await fetch(url, { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data||{}) })).json(); },
      async put(url, data) { return (await fetch(url, { method: 'PUT', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data) })).json(); },
      async del(url) { return (await fetch(url, { method: 'DELETE' })).json(); }
    };

    function showLoading() { document.getElementById('loadingSpinner').classList.remove('d-none'); }
    function hideLoading() { document.getElementById('loadingSpinner').classList.add('d-none'); }
    function showToast(msg) { document.getElementById('toastMsg').innerText = msg; new bootstrap.Toast(document.getElementById('appToast')).show(); }
    function toggleTheme() {
      const html = document.documentElement;
      if (html.getAttribute('data-theme') === 'dark') { html.removeAttribute('data-theme'); localStorage.removeItem('theme'); } 
      else { html.setAttribute('data-theme', 'dark'); localStorage.setItem('theme', 'dark'); }
    }

    async function init() {
      if (!state.user) { renderLogin(); return; }
      showLoading();
      const data = await api.getState();
      state.employees = data.employees; state.attendance = data.attendance; state.salaries = data.salaries;
      hideLoading(); renderApp();
    }

    function renderLogin() {
      document.getElementById('root').innerHTML = `
        <div class="container d-flex align-items-center justify-content-center min-vh-100">
          <div class="glass-panel p-5 fade-in" style="width: 400px;">
            <h3 class="text-center mb-4 fw-bold"><i class="bi bi-boxes text-primary"></i> EMS Enterprise</h3>
            <p class="text-center text-muted mb-4">Modern Enterprise Edition</p>
            <form onsubmit="doLogin(event)">
              <div class="mb-3"><label>Username</label><input id="loginUser" class="form-control" required></div>
              <div class="mb-3"><label>Password</label><input type="password" id="loginPass" class="form-control" required></div>
              <div id="loginError" class="alert alert-danger d-none py-2"></div>
              <button class="btn btn-primary w-100 mt-2">Login</button>
            </form>
            <div class="mt-3 text-center small text-muted">Admin: admin / admin123<br>Employee: EMP001 / emp123</div>
          </div>
        </div>`;
    }

    async function doLogin(e) {
      e.preventDefault();
      const res = await api.login(document.getElementById('loginUser').value, document.getElementById('loginPass').value);
      if (res.success) window.location.reload();
      else { const el = document.getElementById('loginError'); el.classList.remove('d-none'); el.innerText = res.message; }
    }

    function getSidebar() {
      if (state.user.role === 'admin') {
        return `<a class="nav-link" href="#" data-view="dashboard" onclick="navigate('dashboard')"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                <a class="nav-link" href="#" data-view="employees" onclick="navigate('employees')"><i class="bi bi-people me-2"></i> Employees</a>
                <a class="nav-link" href="#" data-view="timesheet" onclick="navigate('timesheet')"><i class="bi bi-clock-history me-2"></i> Timesheet</a>
                <a class="nav-link" href="#" data-view="salary" onclick="navigate('salary')"><i class="bi bi-cash-stack me-2"></i> Salary</a>
                <a class="nav-link" href="#" data-view="reports" onclick="navigate('reports')"><i class="bi bi-bar-chart me-2"></i> Reports</a>`;
      }
      return `<a class="nav-link" href="#" data-view="dashboard" onclick="navigate('dashboard')"><i class="bi bi-speedometer2 me-2"></i> My Dashboard</a>
              <a class="nav-link" href="#" data-view="timesheet" onclick="navigate('timesheet')"><i class="bi bi-clock-history me-2"></i> My Timesheet</a>
              <a class="nav-link" href="#" data-view="salary" onclick="navigate('salary')"><i class="bi bi-cash-stack me-2"></i> My Salary</a>`;
    }

    function getNotifications() {
      let notes = [];
      state.attendance.filter(a => a.status === 'Late').forEach(a => notes.push(`Late: ${a.employeeName}`));
      state.attendance.filter(a => a.status === 'Absent').forEach(a => notes.push(`Absent: ${a.employeeName}`));
      state.salaries.filter(s => s.status === 'Paid').forEach(s => notes.push(`Salary Paid: ${s.employeeName}`));
      if (notes.length === 0) return `<li><a class="dropdown-item" href="#">No new notifications</a></li>`;
      return notes.map(n => `<li><a class="dropdown-item" href="#">${n}</a></li>`).join('');
    }

    function renderApp() {
      document.getElementById('root').innerHTML = `
        <div class="d-flex p-2">
          <aside class="sidebar glass-panel m-2 p-3 d-flex flex-column">
            <h4 class="text-center mb-4 mt-2 fw-bold"><i class="bi bi-boxes text-primary"></i> EMS</h4>
            <nav class="nav flex-column flex-grow-1">${getSidebar()}</nav>
            <button class="btn btn-danger w-100 mt-3" onclick="api.logout()"><i class="bi bi-box-arrow-right"></i> Logout</button>
          </aside>
          <main class="flex-grow-1 p-2">
            <header class="topbar glass-panel p-3 d-flex justify-content-between align-items-center mb-4">
              <h4 id="pageTitle" class="mb-0 fw-bold">Dashboard</h4>
              <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="toggleTheme()"><i class="bi bi-moon-stars"></i></button>
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary rounded-circle" data-bs-toggle="dropdown"><i class="bi bi-bell"></i></button>
                  <ul class="dropdown-menu dropdown-menu-end glass-panel">${getNotifications()}</ul>
                </div>
                <div class="d-flex align-items-center"><span class="me-2 fw-bold">${state.user.name}</span><i class="bi bi-person-circle fs-4"></i></div>
              </div>
            </header>
            <div id="viewContainer" class="fade-in"></div>
            <footer class="text-center p-4 mt-5 text-muted"><p class="mb-0">© 2023 Employee Management System | Modern Enterprise Edition.</p></footer>
          </main>
        </div>`;
      navigate('dashboard');
    }

    function navigate(view) {
      state.currentView = view;
      document.querySelectorAll('.sidebar .nav-link').forEach(el => {
        el.classList.remove('active');
        if (el.getAttribute('data-view') === view) el.classList.add('active');
      });
      const map = { dashboard: 'Dashboard', employees: 'Employees', timesheet: 'Timesheet', salary: 'Salary', reports: 'Reports' };
      document.getElementById('pageTitle').innerText = state.user.role === 'employee' && view === 'dashboard' ? 'My Dashboard' : map[view];
      const container = document.getElementById('viewContainer');
      if (view === 'dashboard') container.innerHTML = viewDashboard();
      if (view === 'employees') container.innerHTML = viewEmployees();
      if (view === 'timesheet') container.innerHTML = viewTimesheet();
      if (view === 'salary') container.innerHTML = viewSalary();
      if (view === 'reports') { container.innerHTML = viewReports(); updateReport(); }

      if (view === 'dashboard' && state.user.role === 'admin') {
        const ctx = document.getElementById('attendanceChart');
        if (ctx) {
          if (window.myChart) window.myChart.destroy();
          window.myChart = new Chart(ctx, { type: 'line', data: { labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul'], datasets: [{ label: 'Attendance', data: [20, 25, 22, 28, 26, state.employees.length, state.employees.length], borderColor: '#4f46e5', backgroundColor: 'rgba(79, 70, 229, 0.2)', fill: true, tension: 0.4 }] } });
        }
      }
    }

    function statCard(title, value, icon, color) {
      return `<div class="col-md-4 col-lg-3 mb-4"><div class="glass-panel p-3 d-flex align-items-center h-100"><i class="bi ${icon} stat-icon me-3" style="color:${color}"></i><div><h6 class="mb-0 text-muted">${title}</h6><h3 class="mb-0 fw-bold">${value}</h3></div></div></div>`;
    }

    function viewDashboard() {
      const t = new Date().toISOString().split('T')[0];
      if (state.user.role === 'employee') {
        const myAtt = state.attendance;
        const present = myAtt.filter(a => a.status==='Present'||a.status==='Late').length;
        const absent = myAtt.filter(a => a.status==='Absent').length;
        const sal = state.salaries[0];
        return `<div class="row">${statCard('Present Days', present, 'bi-check-circle', '#10b981')}${statCard('Absent Days', absent, 'bi-x-circle', '#ef4444')}${statCard('Net Salary', sal ? '$'+sal.net : 'N/A', 'bi-cash', '#4f46e5')}</div>
        <div class="glass-panel p-4 mt-3 text-center"><button class="btn btn-success me-2" onclick="checkIn()">Check In</button><button class="btn btn-warning" onclick="checkOut()">Check Out</button></div>`;
      }
      const totalEmp = state.employees.length;
      const present = state.attendance.filter(a => a.date === t && (a.status==='Present'||a.status==='Late')).length;
      const absent = totalEmp - present;
      const late = state.attendance.filter(a => a.status === 'Late').length;
      const wHrs = state.attendance.reduce((s,a)=>s+(a.workingHours||0),0);
      const oHrs = state.attendance.reduce((s,a)=>s+(a.overtime||0),0);
      const payroll = state.salaries.reduce((s,a)=>s+a.net,0);
      const pending = state.salaries.filter(s=>s.status==='Pending').length;
      const paid = state.salaries.filter(s=>s.status==='Paid').length;
      
      const now = new Date();
      const startOfWeek = new Date(now.setDate(now.getDate() - now.getDay()));
      const weekAtt = state.attendance.filter(a => new Date(a.date) >= startOfWeek).length;
      const weekTotal = totalEmp * 5;
      const weekPct = weekTotal ? Math.min(100, Math.round((weekAtt / weekTotal) * 100)) : 0;

      return `<div class="row">
        ${statCard('Total Employees', totalEmp, 'bi-people', '#4f46e5')}
        ${statCard('Present Today', present, 'bi-check-circle', '#10b981')}
        ${statCard('Absent Today', absent, 'bi-x-circle', '#ef4444')}
        ${statCard('Late Employees', late, 'bi-clock', '#f59e0b')}
        ${statCard('Working Hours', wHrs, 'bi-hourglass-split', '#3b82f6')}
        ${statCard('Overtime Hours', oHrs, 'bi-stopwatch', '#8b5cf6')}
        ${statCard('Monthly Payroll', '$'+payroll, 'bi-cash-stack', '#14b8a6')}
        ${statCard('Pending Salaries', pending, 'bi-hourglass', '#ef4444')}
        ${statCard('Paid Salaries', paid, 'bi-check2-all', '#10b981')}
      </div>
      <div class="col-12 mb-4"><div class="glass-panel p-3">
        <h6 class="text-muted">Weekly Attendance Summary</h6>
        <div class="progress" style="height: 20px; border-radius: 10px; background: rgba(0,0,0,0.1);">
          <div class="progress-bar bg-primary" role="progressbar" style="width: ${weekPct}%; border-radius: 10px;" aria-valuenow="${weekPct}" aria-valuemin="0" aria-valuemax="100">${weekPct}%</div>
        </div>
      </div></div>
      <div class="glass-panel p-4 mt-3"><h5 class="mb-4">Monthly Attendance Chart</h5><canvas id="attendanceChart" height="100"></canvas></div>`;
    }

    function viewEmployees() {
      return `<div class="d-flex justify-content-between mb-3 flex-wrap gap-2">
        <input type="text" id="empSearch" class="form-control w-50" placeholder="Search by Name, ID, Dept..." onkeyup="filterTable('empSearch', 'empTableBody')">
        <button class="btn btn-primary" onclick="openEmpModal()"><i class="bi bi-plus-lg"></i> Add Employee</button>
      </div>
      <div class="glass-panel p-3 table-responsive"><table class="table table-hover align-middle">
        <thead><tr><th>Photo</th><th>ID</th><th>Name</th><th>Dept</th><th>Trade</th><th>Salary</th><th>Status</th><th>Action</th></tr></thead>
        <tbody id="empTableBody">${state.employees.map(e => `<tr>
          <td><img src="${e.photo}" class="rounded-circle" width="40" height="40"></td>
          <td>${e.id}</td><td>${e.name}</td><td>${e.department}</td><td>${e.trade}</td>
          <td>
$$
{e.salary}</td><td><span class="badge bg-${e.status==='Active'?'success':'danger'} badge-custom">${e.status}</span></td>
          <td><button class="btn btn-sm btn-info me-1" onclick="openEmpModal('${e.id}')"><i class="bi bi-pencil"></i></button>
          <button class="btn btn-sm btn-danger" onclick="delEmp('${e.id}')"><i class="bi bi-trash"></i></button></td></tr>`).join('')}</tbody>
      </table></div>`;
    }

    function openEmpModal(id = null) {
      const m = new bootstrap.Modal(document.getElementById('empModal'));
      if (id) {
        const e = state.employees.find(x => x.id === id);
        document.getElementById('empModalTitle').innerText = 'Edit Employee';
        document.getElementById('empId').value = e.id; document.getElementById('empName').value = e.name;
        document.getElementById('empEid').value = e.id; document.getElementById('empDept').value = e.department;
        document.getElementById('empTrade').value = e.trade; document.getElementById('empNat').value = e.nationality;
        document.getElementById('empEmirates').value = e.emiratesId; document.getElementById('empPass').value = e.passport;
        document.getElementById('empPhone').value = e.phone; document.getElementById('empEmail').value = e.email;
        document.getElementById('empSalary').value = e.salary; document.getElementById('empJoin').value = e.joiningDate;
        document.getElementById('empStatus').value = e.status; document.getElementById('empPhoto').value = e.photo;
      } else {
        document.getElementById('empModalTitle').innerText = 'Add Employee'; document.getElementById('empForm').reset();
        document.getElementById('empEid').value = 'EMP' + Math.floor(Math.random()*10000);
      }
      m.show();
    }

    async function saveEmployee() {
      const id = document.getElementById('empId').value;
      const data = {
        id: document.getElementById('empEid').value, name: document.getElementById('empName').value,
        department: document.getElementById('empDept').value, trade: document.getElementById('empTrade').value,
        nationality: document.getElementById('empNat').value, emiratesId: document.getElementById('empEmirates').value,
        passport: document.getElementById('empPass').value, phone: document.getElementById('empPhone').value,
        email: document.getElementById('empEmail').value, salary: parseFloat(document.getElementById('empSalary').value),
        joiningDate: document.getElementById('empJoin').value, status: document.getElementById('empStatus').value,
        photo: document.getElementById('empPhoto').value
      };
      showLoading();
      if (id) await api.put('/api/employees/' + id, data); else await api.post('/api/employees', data);
      const d = await api.getState(); state.employees = d.employees; state.attendance = d.attendance; state.salaries = d.salaries;
      hideLoading(); bootstrap.Modal.getInstance(document.getElementById('empModal')).hide(); showToast('Saved!'); navigate('employees');
    }

    async function delEmp(id) {
      if (!confirm('Delete employee?')) return;
      showLoading(); await api.del('/api/employees/' + id);
      const d = await api.getState(); state.employees = d.employees; hideLoading(); navigate('employees'); showToast('Deleted!');
    }

    function viewTimesheet() {
      const isEmp = state.user.role === 'employee';
      return `${isEmp ? `<div class="text-center mb-3"><button class="btn btn-success me-2" onclick="checkIn()">Check In</button><button class="btn btn-warning" onclick="checkOut()">Check Out</button></div>` : ''}
      <div class="d-flex justify-content-between mb-3"><input type="text" id="attSearch" class="form-control w-50" placeholder="Search..." onkeyup="filterTable('attSearch', 'attTableBody')"></div>
      <div class="glass-panel p-3 table-responsive"><table class="table table-hover">
        <thead><tr><th>Emp ID</th><th>Name</th><th>Dept</th><th>Date</th><th>Check In</th><th>Check Out</th><th>Break</th><th>Work Hrs</th><th>OT</th><th>Status</th><th>Remarks</th></tr></thead>
        <tbody id="attTableBody">${state.attendance.map(a => `<tr>
          <td>${a.employeeId}</td><td>${a.employeeName}</td><td>${a.department}</td><td>${a.date}</td>
          <td>${a.checkIn}</td><td>${a.checkOut}</td><td>${a.breakTime}h</td><td>${a.workingHours}</td><td>${a.overtime}</td>
          <td><span class="badge bg-info badge-custom">${a.status}</span></td><td>${a.remarks}</td></tr>`).join('')}</tbody>
      </table></div>`;
    }

    async function checkIn() { showLoading(); await api.post('/api/attendance/checkin'); const d = await api.getState(); Object.assign(state, d); hideLoading(); navigate('timesheet'); }
    async function checkOut() { showLoading(); await api.post('/api/attendance/checkout'); const d = await api.getState(); Object.assign(state, d); hideLoading(); navigate('timesheet'); }

    function viewSalary() {
      const isAdmin = state.user.role === 'admin';
      return `${isAdmin ? `<div class="mb-3"><button class="btn btn-primary" onclick="genPayroll()"><i class="bi bi-generate"></i> Generate Monthly Payroll</button></div>` : ''}
      <div class="d-flex justify-content-between mb-3"><input type="text" id="salSearch" class="form-control w-50" placeholder="Search..." onkeyup="filterTable('salSearch', 'salTableBody')"></div>
      <div class="glass-panel p-3 table-responsive"><table class="table table-hover">
        <thead><tr><th>Emp ID</th><th>Name</th><th>Basic</th><th>Allow</th><th>OT</th><th>Deduct</th><th>Net</th><th>Status</th><th>Action</th></tr></thead>
        <tbody id="salTableBody">${state.salaries.map(s => `<tr>
          <td>${s.employeeId}</td><td>${s.employeeName}</td><td>
$$
{s.basic}</td><td>$${s.allowance}</td><td>$${s.overtime}</td><td>
$$
{s.deductions}</td>
          <td class="fw-bold">
$$
{s.net}</td><td><span class="badge bg-${s.status==='Paid'?'success':'warning'} badge-custom">${s.status}</span></td>
          <td>${isAdmin && s.status==='Pending' ? `<button class="btn btn-sm btn-success" onclick="openPay('${s.id}')">Pay</button>` : `<button class="btn btn-sm btn-info" onclick="genSlip('${s.id}')">Slip</button>`}</td></tr>`).join('')}</tbody>
      </table></div>`;
    }

    async function genPayroll() { showLoading(); await api.post('/api/salaries/generate'); const d = await api.getState(); Object.assign(state, d); hideLoading(); navigate('salary'); showToast('Payroll Generated!'); }

    function openPay(id) {
      document.getElementById('paySalId').value = id; document.getElementById('payDate').value = new Date().toISOString().split('T')[0];
      new bootstrap.Modal(document.getElementById('payModal')).show();
    }
    async function processPayment() {
      const id = document.getElementById('paySalId').value;
      showLoading(); await api.post('/api/salaries/pay/' + id, { method: document.getElementById('payMethod').value, transactionId: document.getElementById('payTxn').value, reference: document.getElementById('payRef').value, date: document.getElementById('payDate').value });
      const d = await api.getState(); Object.assign(state, d); hideLoading(); bootstrap.Modal.getInstance(document.getElementById('payModal')).hide(); navigate('salary'); showToast('Payment Processed!');
    }
    function genSlip(id) {
      const s = state.salaries.find(x => x.id === id); const { jsPDF } = window.jspdf; const doc = new jsPDF();
      doc.setFontSize(18); doc.text("EMS Salary Slip", 14, 20); doc.setFontSize(12);
      doc.text(`Employee: ${s.employeeName} (${s.employeeId})`, 14, 35); doc.text(`Month/Year: ${s.month+1}/${s.year}`, 14, 45);
      doc.text(`Basic: $${s.basic} | Allow: $${s.allowance} | OT: 
$$
{s.overtime}`, 14, 55);
      doc.text(`Bonus: 
$$
{s.bonus} | Comm: 
$$
{s.commission}`, 14, 65);
      doc.text(`Adv: 
$$
{s.advance} | Pen: $${s.penalty} | Loan: $${s.loan}`, 14, 75);
      doc.text(`Deductions: $${s.deductions} | Net: $${s.net}`, 14, 85); doc.text(`Status: ${s.status}`, 14, 95);
      if(s.status==='Paid') doc.text(`Method: ${s.paymentMethod} | Txn: ${s.transactionId} | Ref: ${s.reference}`, 14, 105);
      doc.save(`Slip_${s.employeeId}.pdf`);
    }

    function viewReports() {
      return `<div class="glass-panel p-4 mb-3 d-flex justify-content-between flex-wrap gap-2">
        <h4 class="fw-bold mb-0">Reports Center</h4>
        <div class="d-flex gap-2">
          <select id="reportType" class="form-select w-auto" onchange="updateReport()">
            <option value="daily">Daily Attendance</option><option value="weekly">Weekly Report</option>
            <option value="monthly">Monthly Report</option><option value="employee">Employee Report</option>
            <option value="payroll">Payroll Report</option><option value="salary">Salary Report</option>
            <option value="late">Late Report</option><option value="overtime">Overtime Report</option>
          </select>
          <button class="btn btn-danger" onclick="expPDF()"><i class="bi bi-file-earmark-pdf"></i> PDF</button>
          <button class="btn btn-success" onclick="expExcel()"><i class="bi bi-file-earmark-excel"></i> Excel</button>
        </div>
      </div>
      <div class="glass-panel p-3 table-responsive"><table id="reportTable" class="table table-hover"></table></div>`;
    }

    function updateReport() {
      const type = document.getElementById('reportType').value;
      const tbody = document.getElementById('reportTable');
      let html = '';
      if (type === 'employee') {
        html = `<thead><tr><th>ID</th><th>Name</th><th>Dept</th><th>Trade</th><th>Salary</th><th>Status</th></tr></thead><tbody>${state.employees.map(e=>`<tr><td>${e.id}</td><td>${e.name}</td><td>${e.department}</td><td>${e.trade}</td><td>
$$
{e.salary}</td><td>${e.status}</td></tr>`).join('')}</tbody>`;
      } else if (type === 'late') {
        const data = state.attendance.filter(a => a.status === 'Late');
        html = `<thead><tr><th>Emp</th><th>Date</th><th>Check In</th><th>Status</th><th>Remarks</th></tr></thead><tbody>${data.map(a=>`<tr><td>${a.employeeName}</td><td>${a.date}</td><td>${a.checkIn}</td><td>${a.status}</td><td>${a.remarks}</td></tr>`).join('')}</tbody>`;
      } else if (type === 'overtime') {
        const data = state.attendance.filter(a => a.overtime > 0);
        html = `<thead><tr><th>Emp</th><th>Date</th><th>Work Hrs</th><th>Overtime</th></tr></thead><tbody>${data.map(a=>`<tr><td>${a.employeeName}</td><td>${a.date}</td><td>${a.workingHours}</td><td>${a.overtime}</td></tr>`).join('')}</tbody>`;
      } else if (type === 'payroll' || type === 'salary') {
        html = `<thead><tr><th>Emp</th><th>Basic</th><th>Allow</th><th>OT</th><th>Net</th><th>Status</th></tr></thead><tbody>${state.salaries.map(s=>`<tr><td>${s.employeeName}</td><td>
$$
{s.basic}</td><td>$${s.allowance}</td><td>$${s.overtime}</td><td>$${s.net}</td><td>${s.status}</td></tr>`).join('')}</tbody>`;
      } else {
        const todayStr = new Date().toISOString().split('T')[0];
        let data = state.attendance;
        if (type === 'daily') data = data.filter(a => a.date === todayStr);
        else if (type === 'monthly') data = data.filter(a => new Date(a.date).getMonth() === new Date().getMonth());
        else if (type === 'weekly') {
          const now = new Date(); const start = new Date(now.setDate(now.getDate() - now.getDay()));
          data = data.filter(a => new Date(a.date) >= start);
        }
        html = `<thead><tr><th>Emp</th><th>Dept</th><th>Date</th><th>In</th><th>Out</th><th>Status</th></tr></thead><tbody>${data.map(a=>`<tr><td>${a.employeeName}</td><td>${a.department}</td><td>${a.date}</td><td>${a.checkIn}</td><td>${a.checkOut}</td><td>${a.status}</td></tr>`).join('')}</tbody>`;
      }
      tbody.innerHTML = html;
    }

    function expPDF() {
      const { jsPDF } = window.jspdf; const doc = new jsPDF();
      doc.text("EMS Report - " + document.getElementById('reportType').value.toUpperCase(), 14, 16);
      doc.autoTable({ html: '#reportTable', startY: 20, headStyles: {fillColor: [79, 70, 229]} });
      doc.save('EMS_Report.pdf');
    }
    function expExcel() {
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, XLSX.utils.table_to_sheet(document.getElementById('reportTable')), "Report");
      XLSX.writeFile(wb, 'EMS_Report.xlsx');
    }

    function filterTable(inputId, tbodyId) {
      const q = document.getElementById(inputId).value.toLowerCase();
      document.querySelectorAll(`#${tbodyId} tr`).forEach(r => r.style.display = r.innerText.toLowerCase().includes(q) ? '' : 'none');
    }

    window.onload = init;
  </script>
</body>
</html>
